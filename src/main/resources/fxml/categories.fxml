<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.financeapp.controllers.CategoryController">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <top>
        <Label text="Categorías" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    </top>

    <center>
        <TableView fx:id="table" prefHeight="400.0">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60.0"/>
                <TableColumn fx:id="colName" text="Nombre" prefWidth="250.0"/>
                <TableColumn fx:id="colKind" text="Tipo" prefWidth="120.0"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="10"/>
            </padding>

            <Button text="Añadir" onAction="#onAdd"/>
            <Button text="Editar" onAction="#onEdit"/>
            <Button text="Eliminar" onAction="#onDelete"/>
        </HBox>
    </bottom>

</BorderPane>